{
  // Agent configuration for the LangGraph MCP realtime system.
  // Each agent binds a graph type to a DCF channel and LLM backend.
  "agents": [
    {
      "name": "echo-agent",
      "graph": "base",
      "llm_backend": "echo",
      "channel": "echo",
      "mesh_url": "http://127.0.0.1:8765",
      "poll_interval": 1.0
    },
    {
      "name": "coordinator-agent",
      "graph": "coordinator",
      "llm_backend": "grok",
      "channel": "agent",
      "mesh_url": "http://127.0.0.1:8765",
      "poll_interval": 0.5
    },
    {
      "name": "glm5p2-agent",
      "graph": "coordinator",
      "llm_backend": "glm5p2",
      "channel": "glm",
      "mesh_url": "http://127.0.0.1:8765",
      "poll_interval": 1.0
    }
  ],
  // Universal provider configs — register any OpenAI-compatible API.
  // "provider" selects a preset (fireworks, openai, grok, ollama, etc.),
  // or omit it and use base_url + api_key + model directly.
  "providers": [
    {
      "name": "fireworks-glm5p2",
      "provider": "fireworks",
      "model": "accounts/fireworks/models/glm-5p2"
    },
    {
      "name": "ollama-local",
      "provider": "ollama",
      "model": "llama3"
    }
  ],
  "mesh_server": {
    "command": "python3",
    "args": ["matrix-bridge/mesh_mcp.py", "http"],
    "port": 8765,
    "host": "127.0.0.1",
    "url": "http://127.0.0.1:8765"
  },
  "api_server": {
    "host": "0.0.0.0",
    "port": 8000
  }
}
