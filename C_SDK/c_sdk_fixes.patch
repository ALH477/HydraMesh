--- a/src/dcf_connpool.c
+++ b/src/dcf_connpool.c
@@
-        dcf_sleep_ms(10000);
+        pool_sleep_interruptible(pool, 10000);
@@
-        dcf_sleep_ms(pool->config.validation_interval_ms);
+        pool_sleep_interruptible(pool, pool->config.validation_interval_ms);


# ----------------------------------------------------------- [RECONSTRUCTED]
# dcf_connpool.c (4/4) — set health_started when the thread is created in
# start(), and JOIN it in stop(). stop() previously joined only the eviction
# thread; destroy() then freed the pool while the health thread was still
# reading pool->running — a use-after-free. If your start()/stop() bodies have
# drifted, the complete corrected functions are quoted in DCF_CODE_REVIEW.md.
--- a/src/dcf_connpool.c
+++ b/src/dcf_connpool.c
@@
-        dcf_thread_create(&pool->health_thread, health_check_loop, pool);
+        if (dcf_thread_create(&pool->health_thread, health_check_loop, pool) == 0) {
+            atomic_store(&pool->health_started, true);
+        }
@@
     atomic_store(&pool->running, false);
     dcf_thread_join(pool->eviction_thread);
+    if (atomic_load(&pool->health_started)) {
+        dcf_thread_join(pool->health_thread);
+        atomic_store(&pool->health_started, false);
+    }


