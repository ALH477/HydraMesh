# ----------------------------------------------------------- [RECONSTRUCTED]
# DOOM_udp_transport.c — udp_send silently truncated payloads > 512 B and
# returned success (data loss), and sent from an uninitialized sockaddr_in
# (leaked padding into the wire address). Reject oversize, zero the address,
# require a full send.
--- a/src/transports/DOOM_udp_transport.c
+++ b/src/transports/DOOM_udp_transport.c
@@
 static bool udp_send(const uint8_t* data, size_t len, const char* dest) {
+    if (len > 512) {
+        return false;   /* was: silent truncation + return true (data loss) */
+    }
     struct sockaddr_in dest_addr;
+    memset(&dest_addr, 0, sizeof(dest_addr));
     dest_addr.sin_family = AF_INET;
@@
-    sendto(sock, data, len, 0, (struct sockaddr*)&dest_addr, sizeof(dest_addr));
-    return true;
+    ssize_t sent = sendto(sock, data, len, 0,
+                          (struct sockaddr*)&dest_addr, sizeof(dest_addr));
+    return sent == (ssize_t)len;


# ----------------------------------------------------------- [RECONSTRUCTED]
# serial_transport.c — allocated a COBS buffer, never encoded into it, then
# transmitted that uninitialized heap (corruption + heap-memory disclosure).
# Until real COBS framing exists, send the payload as-is and report the exact
# byte count. NOTE: framed receivers need a real delimiter; tracked in review.
--- a/src/transports/serial_transport.c
+++ b/src/transports/serial_transport.c
@@
 static bool serial_send(const uint8_t* data, size_t len, const char* dest) {
     (void)dest;
-    uint8_t* cobs = malloc(len + 2);
-    if (!cobs) return false;
-    /* TODO: COBS encode */
-    ssize_t written = write(serial_fd, cobs, len + 2);
-    free(cobs);
-    return written == (ssize_t)(len + 2);
+    /* Fake COBS removed: the buffer was never populated, so this transmitted
+     * uninitialized heap. Send the payload directly until real COBS lands. */
+    ssize_t written = write(serial_fd, data, len);
+    return written == (ssize_t)len;
 }


# ----------------------------------------------------------- [RECONSTRUCTED]
# streamdb.c (1/2) — deleting the last key frees the root node and leaves
# db->root dangling; the next insert dereferences freed memory. Re-establish
# an empty root so the invariant "root is never NULL" holds.
--- a/src/streamdb.c
+++ b/src/streamdb.c
@@
 int streamdb_delete(StreamDB* db, const unsigned char* key, size_t key_len) {
     if (!db || !key) return STREAMDB_ERR_NULL;
     remove_helper(db->root, key, key_len, 0);
+    if (db->root == NULL) {
+        /* last key removed: remove_helper freed the root. Recreate an empty
+         * root so subsequent inserts don't dereference a freed pointer. */
+        db->root = create_node();
+        if (!db->root) return STREAMDB_ERR_NOMEM;
+    }
     return STREAMDB_OK;
 }


