# ----------------------------------------------------------- [RECONSTRUCTED]
# dcf_platform.c — dcf_cond_timedwait built its deadline on CLOCK_REALTIME,
# so a wall-clock jump (NTP step, manual set) could hang the wait. Use the
# monotonic clock, matching the condvar's clock attr.
--- a/src/dcf_platform.c
+++ b/src/dcf_platform.c
@@
-    clock_gettime(CLOCK_REALTIME, &ts);
+    clock_gettime(CLOCK_MONOTONIC, &ts);   /* condvar uses CLOCK_MONOTONIC attr */


# ----------------------------------------------------------- [RECONSTRUCTED]
# dcf_plugin_manager.h — the legacy 4-function transport struct was also named
# ITransport, colliding with the rich 11-member ITransport in dcf_types.h.
# Rename the legacy ABI to DCFTransportV1 and pull in the canonical header so a
# plugin and the core can be compiled in one TU. Plugins migrate with a
# one-token change (see the udp hunk below); the loader casts on dlsym.
--- a/include/dcf_plugin_manager.h
+++ b/include/dcf_plugin_manager.h
@@
+#include "dcf_types.h"   /* rich ITransport (v2 ABI) for the core */
+
+/* v1 plugin ABI. Was named ITransport here and clashed with dcf_types.h.
+ * New plugins should target the rich ITransport in dcf_types.h; existing
+ * v1 plugins keep working by renaming their struct type to DCFTransportV1. */
 typedef struct {
     bool (*init)(const DCFConfig* config);
     bool (*send)(const uint8_t* data, size_t len, const char* dest);
     bool (*receive)(uint8_t* buffer, size_t* len, char* src);
     void (*cleanup)(void);
-} ITransport;
+} DCFTransportV1;


