# ----------------------------------------------------------- [RECONSTRUCTED]
# dcf_platform.h — DCF_INTERNAL used a GCC-only attribute unconditionally,
# breaking the MSVC builds the codebase otherwise supports.
--- a/include/dcf_platform.h
+++ b/include/dcf_platform.h
@@
