# ----------------------------------------------------------- [RECONSTRUCTED]
# sctp_transport.c — recv length is read into a size_t out-param; the
# "*size < 0" error check is dead (unsigned can't be negative). Capture the
# signed return first.
--- a/src/transports/sctp_transport.c
+++ b/src/transports/sctp_transport.c
@@
-    *size = sctp_recvmsg(fd, buffer, *size, NULL, 0, NULL, NULL);
-    if ((ssize_t)*size < 0) {
+    ssize_t n = sctp_recvmsg(fd, buffer, *size, NULL, 0, NULL, NULL);
+    if (n < 0) {
         return false;
     }
+    *size = (size_t)n;


