# DCF C SDK v5.2.0 — critical fixes
# DeMoD LLC · DCF mono repo
#
# APPLY:
#   cd C_SDK   (the directory that contains include/ and src/)
#   git apply --recount --reject ../c_sdk_fixes.patch
#
#   --recount  : re-derives @@ line numbers from context, so the hunk offsets
#                below do not need to match your tree exactly.
#   --reject   : any hunk whose *context* has drifted from your sources lands
#                as a .rej file instead of aborting the whole patch. Apply those
#                by hand using the matching, fully-quoted fix in DCF_CODE_REVIEW.md.
#
# TWO TIERS:
#   [VERIFIED]      reproduced from your headers and diffed mechanically — these
#                   should apply cleanly.
#   [RECONSTRUCTED] anchored on the exact buggy line documented in the review,
#                   with minimal surrounding context. If a .rej appears, the
#                   review carries the complete replacement function.
#
# NOT INCLUDED (quarantine — see review, do not patch): bluetooth_transport.c,
# unified_dual_transport.c, quic_transport.c, irc_transport.c (base64),
# zigbee_transport.c. They are written against APIs/ABIs that no longer exist;
# exclude them from the build rather than patch them.
# ============================================================================


# ---------------------------------------------------------------- [VERIFIED]
# dcf_interface.h — remove the duplicate DCFCmd enum. dcf_types.h already
# defines DCFCmd (DCF_CMD_UNKNOWN=0 ...). The copy here started at
# DCF_CMD_INIT=0, so the two disagreed on every value: a TU including both
# failed to compile; a TU including only one got a different command<->int map.
--- a/include/dcf_interface.h
+++ b/include/dcf_interface.h
@@ -1,27 +1,13 @@
 #ifndef DCF_INTERFACE_H
 #define DCF_INTERFACE_H
+#include "dcf_types.h"   /* canonical DCFCmd (DCF_CMD_UNKNOWN=0 ...) lives here */
 #include "dcf_client.h"
 #include "dcf_error.h"
 
-typedef enum {
-    DCF_CMD_INIT,
-    DCF_CMD_START,
-    DCF_CMD_STOP,
-    DCF_CMD_STATUS,
-    DCF_CMD_SEND,
-    DCF_CMD_RECEIVE,
-    DCF_CMD_HEALTH_CHECK,
-    DCF_CMD_LIST_PEERS,
-    DCF_CMD_HEAL,
-    DCF_CMD_VERSION,
-    DCF_CMD_BENCHMARK,
-    DCF_CMD_GROUP_PEERS,
-    DCF_CMD_SIMULATE_FAILURE,
-    DCF_CMD_LOG_LEVEL,
-    DCF_CMD_LOAD_PLUGIN,
-    DCF_CMD_TUI,
-    DCF_CMD_UNKNOWN
-} DCFCmd;
+/* DCFCmd is defined once, in dcf_types.h. The duplicate enum that used to live
+ * here started at DCF_CMD_INIT=0 and silently disagreed with dcf_types.h on
+ * every numeric value; any TU including both headers failed to compile, and
+ * any that included only one got a different command<->int mapping. */
 
 DCFError dcf_interface_execute(DCFClient* client, DCFCmd cmd, const char** args, int arg_count, bool json_output, char** output);
 DCFError dcf_interface_tui_start(DCFClient* client);
 #endif


