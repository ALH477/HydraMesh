# ----------------------------------------------------------- [RECONSTRUCTED]
# dcf_connpool.c (2/4) — interruptible sleep helper. The eviction/health loops
# slept in one long dcf_sleep_ms() call, so stop() could block for up to the
# full interval (10 s by default) waiting for a thread that was already asked to
# quit. Sleep in short slices and bail the moment running clears.
--- a/src/dcf_connpool.c
+++ b/src/dcf_connpool.c
@@
+/* Sleep up to total_ms, waking immediately when the pool stops. */
+static void pool_sleep_interruptible(DCFConnPool* pool, uint32_t total_ms) {
+    const uint32_t slice = 100;
+    uint32_t elapsed = 0;
+    while (elapsed < total_ms && atomic_load(&pool->running)) {
+        uint32_t step = (total_ms - elapsed < slice) ? (total_ms - elapsed) : slice;
+        dcf_sleep_ms(step);
+        elapsed += step;
+    }
+}


